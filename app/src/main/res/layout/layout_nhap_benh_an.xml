<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".UI.MainNhapBenhAn">
    <!-- Toolbar với nút back -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#3F51B5"
        app:title="Nhập Bệnh Án"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back_white_24dp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Tên bệnh -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên bệnh"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>


        <EditText
            android:id="@+id/edtTenBenh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập tên bệnh"
            android:backgroundTint="#BDBDBD"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mô tả bệnh"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/edtMoTa"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Nhập mô tả bệnh"
            android:backgroundTint="#BDBDBD"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- Đính kèm tệp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đính kèm tệp"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"/>


            <Button
                android:id="@+id/btnChonTep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn tệp"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:backgroundTint="#E0E0E0"/>
            <!-- Hiển thị tên tệp đã chọn -->
            <TextView
                android:id="@+id/tvTenTep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa chọn tệp"
                android:textSize="15sp"
                android:textColor="#666666"
                android:padding="12dp"
                android:background="#F0F0F0"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />
        </LinearLayout>


        <!-- Nhóm nút Lưu / Sửa / Xóa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">


            <Button
                android:id="@+id/btnLuu"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Lưu"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:layout_marginEnd="8dp"
                android:padding="12dp"/>


            <Button
                android:id="@+id/btnSua"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Sửa"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FFC107"
                android:layout_marginEnd="8dp"
                android:padding="12dp"/>


            <Button
                android:id="@+id/btnXoa"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Xóa"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#F44336"
                android:padding="12dp"/>

        </LinearLayout>
    </LinearLayout>
    <ListView
        android:id="@+id/lvBenhAn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="#FFFAEB"
        android:textColor="#090909"
        android:textSize="25sp" />

</LinearLayout>
