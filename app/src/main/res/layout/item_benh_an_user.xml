<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Tên bệnh -->
        <TextView
            android:id="@+id/tvTenBenh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên bệnh: Viêm họng"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#3F51B5"
            android:layout_marginBottom="12dp" />

        <!-- Mô tả bệnh -->
        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mô tả: Bệnh nhân bị đau họng, ho có đờm, sốt nhẹ..."
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="16dp" />

        <!-- Đính kèm tệp (nếu có) -->
        <TextView
            android:id="@+id/tvDinhKem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tệp đính kèm: ketqua_xetnghiem.pdf"
            android:textSize="15sp"
            android:textColor="#1976D2"
            android:textStyle="italic"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>